---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface RelatedPost {
  slug: string;
  title: string;
  description: string;
  date: string;
  tags?: string[];
  image?: ImageMetadata;
}

interface Props {
  title: string;
  description: string;
  date: string;
  updatedDate?: string;
  tags?: string[];
  image?: ImageMetadata;
  readingTime?: number;
  relatedPosts?: RelatedPost[];
  prevPost?: { slug: string; title: string };
  nextPost?: { slug: string; title: string };
  tocNumbered?: boolean;
}

const { title, description, date, updatedDate, tags = [], image, readingTime, relatedPosts = [], prevPost, nextPost, tocNumbered = true } = Astro.props;

const formatted = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const formattedUpdated = updatedDate
  ? new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const imageURL = image ? new URL(image.src, Astro.site).toString() : undefined;
const publishedISO = new Date(date).toISOString();

const pageURL = new URL(Astro.url.pathname, Astro.site).toString();
const twitterShareURL = `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageURL)}&text=${encodeURIComponent(title)}`;
const linkedinShareURL = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageURL)}`;

const breadcrumbLD = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',  item: 'https://traviteja.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog',  item: 'https://traviteja.com/blog/' },
    { '@type': 'ListItem', position: 3, name: title },
  ],
});
---

<BaseLayout
  title={`${title} — Raviteja`}
  description={description}
  image={imageURL}
  type="article"
  publishedDate={publishedISO}
>
  <script type="application/ld+json" set:html={breadcrumbLD} slot="head" />

  <!-- Reading progress bar -->
  <div id="reading-progress" style="position:fixed; top:0; left:0; height:2px; width:0%; background:var(--accent); z-index:999; transition:width 0.08s linear;" aria-hidden="true"></div>

  <!-- Back link -->
  <a href="/blog" title="All articles" style="color:var(--fg-muted); font-size:0.875rem;" class="inline-flex items-center gap-1 hover:opacity-70 transition-opacity mb-8">
    ← All articles
  </a>

  <!-- Article header -->
  <header class="mb-10">
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
    <h1 style="color:var(--fg); font-size:2rem; font-weight:700; line-height:1.25; margin:0 0 0.75rem;">
      {title}
    </h1>
    <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap; margin-top:0.25rem;">
      <a href="/about" style="display:flex; align-items:center; gap:0.5rem; text-decoration:none;" title="About Raviteja">
        <img src="/avatar.jpg" alt="Raviteja Tholupunoori" width="32" height="32"
          style="border-radius:50%; object-fit:cover; object-position:center 15%; border:1.5px solid var(--border); flex-shrink:0; width:32px; height:32px; min-width:32px;" />
        <span style="color:var(--fg); font-size:0.875rem; font-weight:500;" class="hover:text-[var(--accent)] transition-colors">Raviteja</span>
      </a>
      <span style="color:var(--border);">·</span>
      <p style="color:var(--fg-muted); font-size:0.875rem; margin:0; display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
        <span>{formatted}</span>
        {formattedUpdated && (
          <>
            <span style="opacity:0.4;">·</span>
            <span>Updated {formattedUpdated}</span>
          </>
        )}
        {readingTime && (
          <>
            <span style="opacity:0.4;">·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </p>
    </div>
  </header>

  <!-- Table of Contents (injected by JS for articles with 3+ H2s) -->
  <nav id="toc" style="display:none; border:1px solid var(--border); border-radius:10px; padding:1rem 1.25rem; margin-bottom:2.5rem; background:var(--bg-subtle);" aria-label="Table of contents">
    <p style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--fg-muted); margin:0 0 0.6rem;">On this page</p>
    <ol id="toc-list" style={`margin:0; padding-left:${tocNumbered ? '1.1rem' : '0'}; display:flex; flex-direction:column; gap:0.3rem; list-style-type:${tocNumbered ? 'decimal' : 'none'};`}></ol>
  </nav>

  <!-- Article body -->
  <article class="prose">
    <slot />
  </article>

  <!-- Share buttons -->
  <div style="border-top:1px solid var(--border); margin-top:2rem; padding-top:1.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
    <span style="color:var(--fg-muted); font-size:0.875rem;">Found this useful? Share it.</span>
    <div style="display:flex; gap:0.75rem;">
      <a
        href={linkedinShareURL}
        target="_blank"
        rel="noopener noreferrer"
        style="display:inline-flex; align-items:center; gap:0.4rem; border:1px solid var(--border); border-radius:8px; padding:0.4rem 0.9rem; font-size:0.82rem; color:var(--fg-muted); background:var(--bg-subtle);"
        class="hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a
        href={twitterShareURL}
        target="_blank"
        rel="noopener noreferrer"
        style="display:inline-flex; align-items:center; gap:0.4rem; border:1px solid var(--border); border-radius:8px; padding:0.4rem 0.9rem; font-size:0.82rem; color:var(--fg-muted); background:var(--bg-subtle);"
        class="hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X / Twitter
      </a>
    </div>
  </div>

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <div style="margin-top:3rem;">
      <h2 style="color:var(--fg); font-size:1rem; font-weight:600; margin:0 0 1.25rem;">Related articles</h2>
      <div class="flex flex-col gap-3">
        {relatedPosts.map(p => (
          <a
            href={`/blog/${p.slug}/`}
            style="display:flex; align-items:stretch; gap:0; border:1px solid var(--border); border-radius:10px; overflow:hidden; background:var(--bg-subtle); text-decoration:none;"
            class="hover:border-[var(--accent)] transition-colors"
          >
            {p.image && (
              <Image
                src={p.image}
                alt={p.title}
                width={120}
                height={63}
                format="webp"
                quality={80}
                style="width:120px; min-width:120px; object-fit:cover; flex-shrink:0;"
              />
            )}
            <div style="padding:0.875rem 1rem; display:flex; flex-direction:column; justify-content:center;">
              <p style="color:var(--fg); font-size:0.875rem; font-weight:600; margin:0 0 0.3rem; line-height:1.3;">{p.title}</p>
              <p style="color:var(--fg-muted); font-size:0.8rem; margin:0; line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">{p.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Prev / Next navigation -->
  {(prevPost || nextPost) && (
    <div style="border-top:1px solid var(--border); margin-top:3rem; padding-top:1.5rem; display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
      <div>
        {prevPost && (
          <a href={`/blog/${prevPost.slug}/`} style="text-decoration:none; display:block;" class="hover:opacity-80 transition-opacity">
            <p style="color:var(--fg-muted); font-size:0.75rem; margin:0 0 0.25rem; text-transform:uppercase; letter-spacing:0.06em;">← Previous</p>
            <p style="color:var(--fg); font-size:0.875rem; font-weight:500; margin:0; line-height:1.4;">{prevPost.title}</p>
          </a>
        )}
      </div>
      <div style="text-align:right;">
        {nextPost && (
          <a href={`/blog/${nextPost.slug}/`} style="text-decoration:none; display:block;" class="hover:opacity-80 transition-opacity">
            <p style="color:var(--fg-muted); font-size:0.75rem; margin:0 0 0.25rem; text-transform:uppercase; letter-spacing:0.06em;">Next →</p>
            <p style="color:var(--fg); font-size:0.875rem; font-weight:500; margin:0; line-height:1.4;">{nextPost.title}</p>
          </a>
        )}
      </div>
    </div>
  )}

  <!-- Footer nav -->
  <div style="border-top:1px solid var(--border); margin-top:2rem; padding-top:1.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.5rem;">
    <a href="/blog" title="Back to all articles" style="color:var(--fg-muted); font-size:0.875rem;" class="hover:opacity-70 transition-opacity">
      ← Back to all articles
    </a>
    <a href="/rss.xml" title="RSS feed" style="color:var(--fg-muted); font-size:0.8rem; display:inline-flex; align-items:center; gap:0.3rem;" class="hover:text-[var(--accent)] transition-colors">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
      RSS
    </a>
  </div>
</BaseLayout>

<script is:inline>
  // Reading progress bar
  (function () {
    var bar = document.getElementById('reading-progress');
    if (!bar) return;
    window.addEventListener('scroll', function () {
      var scrollTop = document.documentElement.scrollTop;
      var docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      bar.style.width = (docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0) + '%';
    }, { passive: true });
  })();

  // Anchor links on H2 / H3
  (function () {
    document.querySelectorAll('.prose h2, .prose h3').forEach(function (heading) {
      if (!heading.id) return;
      var a = document.createElement('a');
      a.href = '#' + heading.id;
      a.className = 'heading-anchor';
      a.setAttribute('aria-hidden', 'true');
      a.textContent = ' #';
      heading.appendChild(a);
    });
  })();

  // Table of Contents — show if 3+ H2s
  (function () {
    var headings = document.querySelectorAll('.prose h2');
    if (headings.length < 3) return;
    var toc = document.getElementById('toc');
    var list = document.getElementById('toc-list');
    if (!toc || !list) return;
    headings.forEach(function (h) {
      if (!h.id) return;
      var li = document.createElement('li');
      var a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent.replace(' #', '').trim();
      a.style.cssText = 'color:var(--fg-muted); font-size:0.875rem; text-decoration:none;';
      a.addEventListener('mouseover', function () { a.style.color = 'var(--accent)'; });
      a.addEventListener('mouseout', function () { a.style.color = 'var(--fg-muted)'; });
      li.appendChild(a);
      list.appendChild(li);
    });
    toc.style.display = 'block';
  })();

  // Copy button on code blocks
  (function () {
    document.querySelectorAll('.prose pre').forEach(function (pre) {
      var btn = document.createElement('button');
      btn.textContent = 'Copy';
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.addEventListener('click', function () {
        var code = pre.querySelector('code');
        if (!code) return;
        navigator.clipboard.writeText(code.textContent || '').then(function () {
          btn.textContent = 'Copied!';
          btn.classList.add('copied');
          setTimeout(function () {
            btn.textContent = 'Copy';
            btn.classList.remove('copied');
          }, 2000);
        });
      });
      pre.style.position = 'relative';
      pre.appendChild(btn);
    });
  })();
</script>
