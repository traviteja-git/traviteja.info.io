                    <img src={skill.src} alt={skill.name} width="22" height="22" style="object-fit:contain; flex-shrink:0;" />
                  ) : (
                    <div style={`width:22px; height:22px; border-radius:4px; background:${skill.bg}; color:#fff; display:flex; align-items:center; justify-content:center; font-size:0.5rem; font-weight:700; flex-shrink:0;`}>
                      {skill.letter}
                    </div>
                  )}
                  <span style="color:var(--fg); font-size:0.82rem; white-space:nowrap;">{skill.name}</span>
                </>
              );
              const sharedStyle = "border:1px solid var(--border); border-radius:10px; padding:0.75rem 0.875rem; background:var(--bg-subtle); display:flex; align-items:center; gap:0.625rem;";
              return skill.href ? (
                <a href={skill.href} style={sharedStyle} class="hover:border-[var(--accent)] transition-colors" title={`Read about ${skill.name}`}>
                  {inner}
                </a>
              ) : (
                <div style={sharedStyle} class="hover:border-[var(--accent)] transition-colors">
                  {inner}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Certifications -->
  <section class="mb-12">
    <h2 class="fade-in" style="color:var(--fg); font-size:1.2rem; font-weight:600; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid var(--border);">
      Certifications
    </h2>
    <div class="grid sm:grid-cols-2 gap-3 fade-in-group">
      {certifications.map((cert: { name: string; subtitle: string; logo?: string; logoUrl?: string }) => (
        <div style="border:1px solid var(--border); border-radius:10px; padding:0.875rem 1.25rem; background:var(--bg-subtle); display:flex; align-items:center; gap:1rem;">
          <img
            src={cert.logo ?? cert.logoUrl}
            alt={cert.name}
            width="40"
            height="40"
            style="border-radius:8px; object-fit:contain; flex-shrink:0;"
          />
          <div>
            <p style="color:var(--fg); font-size:0.85rem; font-weight:600; margin:0 0 0.1rem;">{cert.name}</p>
            <p style="color:var(--fg-muted); font-size:0.75rem; margin:0; line-height:1.4;">{cert.subtitle}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Speaking & Media -->
  <section class="mb-12">
    <h2 class="fade-in" style="color:var(--fg); font-size:1.2rem; font-weight:600; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid var(--border);">
      Speaking & Media
    </h2>
    <div class="fade-in" style="border:1px solid var(--border); border-radius:10px; padding:1rem 1.25rem; background:var(--bg-subtle); display:flex; align-items:flex-start; gap:1rem;">
      <img
        src="/images/logos/airflow_astro.png"
        alt="Astronomer"
        width="44"
        height="44"
        style="border-radius:8px; object-fit:contain; flex-shrink:0; margin-top:2px;"
      />
      <div>
        <p style="color:var(--fg); font-size:0.9rem; font-weight:600; margin:0 0 0.2rem;">Astronomer Podcast — Apache Airflow in Production</p>
        <p style="color:var(--fg-muted); font-size:0.82rem; margin:0 0 0.4rem; line-height:1.5;">
          Featured on the Astronomer podcast discussing real-world Apache Airflow architectures, orchestration patterns, and lessons learned from running Airflow at scale on Kubernetes across GCP and Azure.
        </p>
        <span style="color:var(--fg-muted); font-size:0.75rem;">Astronomer · 2024</span>
      </div>
    </div>
  </section>

  <!-- Achievements -->
  <section class="mb-12">
    <h2 class="fade-in" style="color:var(--fg); font-size:1.2rem; font-weight:600; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid var(--border);">
      Achievements
    </h2>
    <div class="grid sm:grid-cols-2 gap-4 fade-in-group">
      {achievements.map(item => (
        <div style="border:1px solid var(--border); border-radius:10px; padding:1rem 1.25rem; background:var(--bg-subtle); display:flex; align-items:flex-start; gap:0.875rem;">
          <img
            src={item.logo}
            alt={item.title}
            width="52"
            height="52"
            style="border-radius:8px; object-fit:contain; flex-shrink:0;"
          />
          <div>
            <p style="color:var(--fg); font-size:0.875rem; font-weight:600; margin:0 0 0.25rem;">{item.title}</p>
            <p style="color:var(--fg-muted); font-size:0.78rem; margin:0; line-height:1.4;">{item.subtitle}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Recommendations carousel -->
  <section class="mb-12">
    <h2 class="fade-in" style="color:var(--fg); font-size:1.2rem; font-weight:600; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid var(--border);">
      Recommendations
    </h2>

    <div class="fade-in" style="position:relative;">
      {recommendations.map((rec, i) => (
        <div
          class="rec-slide"
          data-index={String(i)}
          style={`border:1px solid var(--border); border-radius:10px; padding:1.5rem; background:var(--bg-subtle); display:${i === 0 ? 'block' : 'none'};`}
        >
          <p style="color:var(--fg); font-size:0.9rem; line-height:1.8; margin:0 0 1.25rem; font-style:italic;">
            "{rec.quote}"
          </p>
          <div style="display:flex; align-items:center; justify-content:space-between; gap:0.5rem; flex-wrap:wrap;">
            <div>
              <p style="color:var(--fg); font-size:0.875rem; font-weight:600; margin:0;">{rec.name}</p>
              <p style="color:var(--fg-muted); font-size:0.78rem; margin:0.15rem 0 0;">{rec.role} · {rec.company}</p>
            </div>
            <span style="color:var(--fg-muted); font-size:0.75rem; white-space:nowrap;">{rec.date}</span>
          </div>
        </div>
      ))}
    </div>

    <div style="display:flex; align-items:center; justify-content:space-between; margin-top:1rem;">
      <button
        id="rec-prev"
        aria-label="Previous recommendation"
        style="background:var(--bg-subtle); border:1px solid var(--border); color:var(--fg-muted); border-radius:8px; width:2.25rem; height:2.25rem; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:1rem; flex-shrink:0;"
      >←</button>

      <div style="display:flex; align-items:center; gap:0.4rem; flex-wrap:wrap; justify-content:center;">
        {recommendations.map((_, i) => (
          <button
            class="rec-dot"
            data-index={String(i)}
            aria-label={`Go to recommendation ${i + 1}`}
            style={`width:0.45rem; height:0.45rem; border-radius:50%; border:none; cursor:pointer; padding:0; background:${i === 0 ? 'var(--fg)' : 'var(--border)'}; transition:background 0.2s;`}
          ></button>
        ))}
      </div>

      <button
        id="rec-next"
        aria-label="Next recommendation"
        style="background:var(--bg-subtle); border:1px solid var(--border); color:var(--fg-muted); border-radius:8px; width:2.25rem; height:2.25rem; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:1rem; flex-shrink:0;"
      >→</button>
    </div>

    <p style="color:var(--fg-muted); font-size:0.8rem; margin:1rem 0 0;">
      <a href="https://linkedin.com/in/traviteja" target="_blank" rel="noopener noreferrer" style="color:var(--accent);">View all on LinkedIn →</a>
    </p>
  </section>

  <script>
    (function () {
      // ── Recommendations carousel ──────────────────────────────────────
      const slides = document.querySelectorAll('.rec-slide');
      const dots   = document.querySelectorAll('.rec-dot');
      const total  = slides.length;
      let current  = 0;

      function goTo(n: number) {
        (slides[current] as HTMLElement).style.display = 'none';
        (dots[current]   as HTMLElement).style.background = 'var(--border)';
        current = (n + total) % total;
        (slides[current] as HTMLElement).style.display = 'block';
        (dots[current]   as HTMLElement).style.background = 'var(--fg)';
      }

      document.getElementById('rec-prev')?.addEventListener('click', () => goTo(current - 1));
      document.getElementById('rec-next')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

      // ── Highlight toggles ─────────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.hl-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const panel   = document.getElementById(btn.dataset.target!) as HTMLElement;
          const isOpen  = panel.classList.contains('open');
          panel.classList.toggle('open', !isOpen);
          btn.classList.toggle('open', !isOpen);
          btn.setAttribute('aria-expanded', String(!isOpen));
          btn.querySelector('.label')!.textContent = isOpen ? 'Show highlights' : 'Hide highlights';
        });
      });

      // ── Scroll fade-in (IntersectionObserver) ─────────────────────────
      const observer = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
      );

      document.querySelectorAll('.fade-in, .fade-in-group').forEach(el => observer.observe(el));
    })();
  </script>

  <!-- Education -->
  <section>
    <h2 class="fade-in" style="color:var(--fg); font-size:1.2rem; font-weight:600; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid var(--border);">
      Education
    </h2>
    <div class="flex flex-col gap-3">
      {education.map(edu => (
        <div class="fade-in" style="border:1px solid var(--border); border-radius:10px; padding:0.875rem 1.25rem; background:var(--bg-subtle); display:flex; align-items:center; gap:1rem;">
          <img
            src={edu.logo}
            alt={edu.school}
            width="48"
            height="48"
            style="border-radius:8px; object-fit:contain; flex-shrink:0;"
          />
          <div>
            <p style="color:var(--fg); font-size:0.9rem; font-weight:600; margin:0 0 0.15rem;">{edu.school}</p>
            <p style="color:var(--fg-muted); font-size:0.82rem; margin:0 0 0.1rem;">{edu.degree}</p>
            <p style="color:var(--fg-muted); font-size:0.78rem; margin:0;">{edu.period} · {edu.grade}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
