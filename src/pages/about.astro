<style>
  /* Fade-in on scroll */
  .fade-in {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children inside a fade-in container */
  .fade-in-group > * {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .fade-in-group.visible > *:nth-child(1) { opacity:1; transform:none; transition-delay:0ms; }
  .fade-in-group.visible > *:nth-child(2) { opacity:1; transform:none; transition-delay:60ms; }
  .fade-in-group.visible > *:nth-child(3) { opacity:1; transform:none; transition-delay:120ms; }
  .fade-in-group.visible > *:nth-child(4) { opacity:1; transform:none; transition-delay:180ms; }
  .fade-in-group.visible > *:nth-child(5) { opacity:1; transform:none; transition-delay:240ms; }
  .fade-in-group.visible > *:nth-child(n+6) { opacity:1; transform:none; transition-delay:300ms; }

  /* Highlight toggle button */
  .hl-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.5rem;
    padding: 0.2rem 0.65rem;
    font-size: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    user-select: none;
  }
  .hl-toggle:hover { color: var(--fg); border-color: var(--fg-muted); }
  .hl-toggle.open  { color: var(--accent); border-color: var(--accent); }
  .hl-toggle .chevron { transition: transform 0.2s; display:inline-block; }
  .hl-toggle.open .chevron { transform: rotate(180deg); }

  /* Highlights panel */
  .hl-panel {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    opacity: 0;
  }
  .hl-panel.open {
    max-height: 600px;
    opacity: 1;
  }
</style>

