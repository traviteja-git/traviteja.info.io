---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const topics = [
  { id: 'airflow',  label: 'Apache Airflow',        tags: ['airflow'] },
  { id: 'ai',       label: 'AI & Developer Tools',   tags: ['ai', 'developer-tools', 'agents', 'llm', 'prompt-engineering'] },
  { id: 'career',   label: 'Career & Community',     tags: ['career', 'community', 'certification'] },
];

function topicFor(postTags: string[]): string {
  for (const t of topics) {
    if (postTags.some(tag => t.tags.includes(tag))) return t.id;
  }
  return 'other';
}

const grouped = topics.map(topic => ({
  ...topic,
  posts: posts.filter(p => (p.data.tags ?? []).some(t => topic.tags.includes(t))),
}));
---

<BaseLayout
  title="Blog — Raviteja Tholupunoori"
  description="Articles on Apache Airflow, AI agents, LLM tooling, GCP data pipelines, and modern data engineering workflows by Raviteja Tholupunoori."
>
  <header class="mb-6">
    <h1 style="color:var(--fg); font-size:2rem; font-weight:700; margin:0 0 0.75rem;">Blog</h1>
    <p style="color:var(--fg-muted); font-size:1rem; margin:0;">
      Articles on Apache Airflow, AI agents, workflow orchestration, and modern data engineering on GCP, AWS and Azure.
    </p>
  </header>

  <!-- Search -->
  <div style="position:relative; margin-bottom:1.5rem;">
    <input
      id="search"
      type="search"
      placeholder="Search articles…"
      autocomplete="off"
      style="width:100%; padding:0.6rem 1rem 0.6rem 2.5rem; border:1px solid var(--border); border-radius:6px; background:var(--bg); color:var(--fg); font-size:0.95rem; box-sizing:border-box;"
    />
    <svg style="position:absolute; left:0.75rem; top:50%; transform:translateY(-50%); color:var(--fg-muted); pointer-events:none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
  </div>

  <!-- Topic tabs -->
  <div id="topic-tabs" class="flex flex-wrap gap-2 mb-8">
    <button class="topic-btn active" data-topic="all">All</button>
    {topics.map(t => (
      <button class="topic-btn" data-topic={t.id}>{t.label}</button>
    ))}
  </div>

  <!-- Search results (hidden unless searching) -->
  <div id="search-results" style="display:none;">
    <p id="search-count" style="color:var(--fg-muted); font-size:0.85rem; margin:0 0 1rem;"></p>
    <div id="search-list" class="flex flex-col"></div>
    <p id="no-results" style="display:none; color:var(--fg-muted); font-size:0.9rem;">No articles match your search.</p>
  </div>

  <!-- Grouped view (all topics) -->
  <div id="grouped-view">
    {grouped.map(topic => topic.posts.length > 0 && (
      <section data-section={topic.id} class="mb-10">
        <h2 style="color:var(--fg); font-size:1rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin:0 0 0.25rem;">
          {topic.label}
        </h2>
        <div style="height:2px; background:var(--accent); width:2.5rem; margin-bottom:1rem;"></div>
        <div class="flex flex-col">
          {topic.posts.map(post => (
            <div class="post-card" data-slug={post.slug}>
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                slug={post.slug}
                tags={post.data.tags}
                image={post.data.image}
              />
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

  <!-- Single topic view (shown when a topic tab is active) -->
  <div id="topic-view" style="display:none;">
    <div id="topic-list" class="flex flex-col">
      {posts.map(post => (
        <div
          class="post-card-topic"
          data-topic={topicFor(post.data.tags ?? [])}
          style="display:none;"
        >
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
            image={post.data.image}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .topic-btn {
    cursor: pointer;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.35rem 0.85rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .topic-btn.active {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }
  #search:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
  }
</style>

<script define:vars={{ topics }}>
  const searchInput = document.getElementById('search');
  const topicBtns = document.querySelectorAll('.topic-btn');
  const groupedView = document.getElementById('grouped-view');
  const topicView = document.getElementById('topic-view');
  const searchResults = document.getElementById('search-results');
  const searchList = document.getElementById('search-list');
  const searchCount = document.getElementById('search-count');
  const noResults = document.getElementById('no-results');
  const topicCards = document.querySelectorAll('.post-card-topic');

  let activeTopic = 'all';

  // Build search index from rendered cards in grouped view
  const allCards = [...document.querySelectorAll('#grouped-view .post-card')];
  const searchIndex = allCards.map(card => {
    const a = card.querySelector('a');
    const h2 = card.querySelector('h2');
    const p = card.querySelector('p');
    return {
      slug: card.dataset.slug,
      title: h2?.textContent?.toLowerCase() ?? '',
      description: p?.textContent?.toLowerCase() ?? '',
      html: card.innerHTML,
    };
  });

  function switchTopic(topic) {
    activeTopic = topic;
    topicBtns.forEach(b => b.classList.toggle('active', b.dataset.topic === topic));

    if (topic === 'all') {
      groupedView.style.display = '';
      topicView.style.display = 'none';
    } else {
      groupedView.style.display = 'none';
      topicView.style.display = '';
      topicCards.forEach(card => {
        card.style.display = card.dataset.topic === topic ? '' : 'none';
      });
    }
  }

  function doSearch(query) {
    const q = query.trim().toLowerCase();

    if (!q) {
      searchResults.style.display = 'none';
      switchTopic(activeTopic);
      return;
    }

    // Hide both views, show search results
    groupedView.style.display = 'none';
    topicView.style.display = 'none';
    searchResults.style.display = '';

    const matches = searchIndex.filter(
      item => item.title.includes(q) || item.description.includes(q)
    );

    searchList.innerHTML = matches.map(m => `<div>${m.html}</div>`).join('');
    const count = matches.length;
    searchCount.textContent = count === 0 ? '' : `${count} article${count === 1 ? '' : 's'} found`;
    noResults.style.display = count === 0 ? '' : 'none';
  }

  topicBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      searchInput.value = '';
      searchResults.style.display = 'none';
      switchTopic(btn.dataset.topic);
    });
  });

  searchInput.addEventListener('input', e => doSearch(e.target.value));
</script>
